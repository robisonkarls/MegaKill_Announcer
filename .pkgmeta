package-as: MegaKill_Announcer

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .github
  - .git
  - .gitignore
  - .gitattributes
  - PUBLISHING.md
  - DEPLOYMENT.md
  - REFACTOR_PLAN.md
  - WAGO_DEPLOY_PLAN.md
  - push.sh
  - "*.md~"
  - "*.bak"

license-output: LICENSE

# Optional: Embed version from tag into TOC files
# enable-toc-creation: yes
